# Client .gitignore (Vite / Bun / Node)

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Dependencies
node_modules/

# Build outputs
dist/
dist-ssr/
build/

# Local env files
.env
.env.*

# Vite / cache
/.vite
.vite

# Bun
bun.lockb

# Lockfiles
package-lock.json
pnpm-lock.yaml
yarn.lock

# Editor directories and files
.vscode/
!.vscode/extensions.json
.idea/
.DS_Store

# Misc
coverage/
.cache/
*.local
